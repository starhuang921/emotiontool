page {
  background-color: #f9f2f4;
}
.container {
  padding: 30rpx;
}
.detail-box {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
}
.detail-title {
  font-size: 44rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 40rpx;
}
.detail-section {
  margin-bottom: 40rpx;
}
.label {
  font-size: 32rpx;
  font-weight: bold;
  color: #e799a0;
  margin-bottom: 20rpx;
}
.content {
  font-size: 30rpx;
  color: #555;
  line-height: 1.7;
}
.suggest {
  white-space: pre-line;
  /* 让换行生效 */
}