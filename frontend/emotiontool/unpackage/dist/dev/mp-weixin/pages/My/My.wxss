.container.data-v-8f9a99c0 {
  width: 750rpx;
  min-height: 100vh;
  background: #f9fafc;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 用户卡片 */
.user-card.data-v-8f9a99c0 {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}
.user-card .avatar.data-v-8f9a99c0 {
  width: 80rpx;
  height: 80rpx;
}
.user-card .username.data-v-8f9a99c0 {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}
.user-card .sign.data-v-8f9a99c0 {
  font-size: 24rpx;
  color: #999;
}

/* 日记卡片 */
.diary-card.data-v-8f9a99c0, .history-card.data-v-8f9a99c0 {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}
.diary-card .title.data-v-8f9a99c0, .history-card .title.data-v-8f9a99c0 {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}
.input.data-v-8f9a99c0 {
  width: 100%;
  min-height: 200rpx;
  background: #f9fafc;
  border-radius: 16rpx;
  padding: 20rpx;
