  font-size: 28rpx;
  margin-bottom: 20rpx;
}
.save-btn.data-v-8f9a99c0 {
  background: #ff6b9d;
  color: #fff;
  border-radius: 44rpx;
  border: none;
  padding: 20rpx;
  font-size: 28rpx;
}

/* 日记列表 */
.item.data-v-8f9a99c0 {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f3f3;
}
.item .item-left.data-v-8f9a99c0 {
